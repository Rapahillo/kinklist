# Database (local Docker PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kinklist?schema=public"

# Resend (email service)
RESEND_API_KEY=
# Sender address for transactional emails (must use a verified domain in Resend)
# The default onboarding@resend.dev only delivers to the Resend account owner
EMAIL_FROM="KinkList <noreply@yourdomain.com>"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
